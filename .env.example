# Sample .env file for IaC Terraform AWS Secrets Manager provisioning
# Place this file as .env in the IaC directory to automatically inject secrets into AWS Secrets Manager (tikto/dev and tikto/prod).

DATABASE_URL=postgresql://postgres:MySecurePassword123!@tikto-db.rds.amazonaws.com:5432/tikto_db
TIKTO_INTERNAL_API_KEY=super-secret-internal-api-key-2026
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_pub_key_example_abcdef123456
